---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllBlogPosts } from '../../data/blog-posts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = loadAllBlogPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
---
<BaseLayout title={`${post.title} | Blog | Prashanth Kumar Kadasi`} currentPath="/blog">
<div class="container" style="max-width: 800px; position: relative; z-index: 1;">
    <div class="row">
        <div class="col-12">
            <a href="/blog" class="btn btn-outline-light btn-sm mb-4">
                <i class="fas fa-arrow-left"></i> Back to Blog
            </a>

            <article>
                <header style="margin-bottom: 2rem;">
                    <span class="blog-date">{post.date}</span>
                    {post.author && (
                        <span style="display: inline-block; background: var(--accent-gradient); color: white; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; margin-left: 0.5rem; vertical-align: middle;">
                            <i class="fas fa-robot" style="margin-right: 4px;"></i>{post.author}
                        </span>
                    )}
                    <h1 style="margin-top: 0.5rem; font-size: 2.5rem;">{post.title}</h1>
                    <div style="margin-top: 1rem;">
                        {post.tags.map((tag) => (
                            <span class="blog-tag">{tag}</span>
                        ))}
                    </div>
                </header>

                <div class="blog-content" set:html={post.content} />
            </article>

            <hr style="border-color: var(--border-glass); margin: 3rem 0;">

            {post.insights && (
                <div class="card" style="border-left: 4px solid #6c5ce7; margin-bottom: 1.5rem;">
                    <div class="card-body">
                        <h5 style="margin: 0 0 0.75rem 0; color: #a29bfe;">
                            <i class="fas fa-lightbulb" style="margin-right: 0.5rem;"></i>My Take
                        </h5>
                        <p style="margin: 0; font-style: italic; color: var(--text-secondary); line-height: 1.7;">
                            "{post.insights}"
                        </p>
                        <p style="margin: 0.5rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);">
                            — Prashanth Kumar Kadasi
                        </p>
                    </div>
                </div>
            )}

            {post.ai_view && post.ai_view.reason && (
                <div class="card" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-left: 4px solid #e94560; margin-bottom: 1.5rem;">
                    <div class="card-body">
                        <h5 style="margin: 0 0 0.75rem 0; color: #e94560;">
                            <i class="fas fa-robot" style="margin-right: 0.5rem;"></i> 🤖 AI View
                        </h5>
                        <div style="margin-bottom: 0.75rem;">
                            {post.ai_view.agrees ? (
                                <span style="display: inline-block; background: #27ae60; color: white; padding: 3px 12px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">
                                    <i class="fas fa-check-circle" style="margin-right: 4px;"></i>Agrees with the author
                                </span>
                            ) : (
                                <span style="display: inline-block; background: #e74c3c; color: white; padding: 3px 12px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">
                                    <i class="fas fa-times-circle" style="margin-right: 4px;"></i>Disagrees with the author
                                </span>
                            )}
                        </div>
                        <p style="margin: 0; color: var(--text-secondary); line-height: 1.7; font-size: 0.95rem;">
                            {post.ai_view.reason}
                        </p>
                        {post.author && (
                            <p style="margin: 0.5rem 0 0 0; font-size: 0.8rem; color: var(--text-muted);">
                                — AI perspective by {post.author}
                            </p>
                        )}
                    </div>
                </div>
            )}

            <!-- Author Card -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div style="width: 60px; height: 60px; background: var(--accent-gradient); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; color: white; margin-right: 1rem;">
                            PK
                        </div>
                        <div>
                            <h5 style="margin: 0;">Prashanth Kumar Kadasi</h5>
                            <p style="margin: 0; font-size: 0.9rem;">Data Analyst & AI Developer</p>
                            {post.author && (
                                <p style="margin: 0.25rem 0 0 0; font-size: 0.8rem; color: var(--text-muted);">
                                    <i class="fas fa-pen-nib" style="margin-right: 4px;"></i>Written with {post.author}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</BaseLayout>
