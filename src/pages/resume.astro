---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EXPERIENCE, RESUME_PROJECTS, RESUME_SKILLS } from '../data/resume';
---
<BaseLayout title="Resume | Prashanth Kumar Kadasi" currentPath="/resume">
<div class="container" style="position: relative; z-index: 1;">
    <!-- Header -->
    <div class="row">
        <div class="col-12">
            <h2>Resume</h2>
            <p class="hero-subtitle" style="font-size: 1.1rem; margin-bottom: 0.5rem;">Data Analyst & AI Developer</p>
            <div style="color: #a0a0b0; margin-bottom: 2rem;">
                <span>📍 Hyderabad, India</span>
            </div>
        </div>
    </div>

    <!-- Summary -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">📋 Summary</div>
                <div class="card-body">
                    <p>Data Analyst & AI Developer with hands-on experience in LLM fine-tuning, model deployment,
                        prompt engineering, and lightweight on-device inference. Skilled in Python, SQL, data engineering,
                        and building AI-powered applications with OpenAI, Gemini, HuggingFace, and custom fine-tuned models.
                        Passionate about applying AI to real-world products, automation, and intelligent systems.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Experience -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">💼 Experience</div>
                <div class="card-body">
                    <h5 style="margin-bottom: 0.25rem;">{EXPERIENCE.company}</h5>
                    <div style="margin-bottom: 1rem;">
                        <span style="font-weight: 600; color: #667eea;">{EXPERIENCE.role}</span>
                        <span style="color: #a0a0b0;"> | {EXPERIENCE.period} | {EXPERIENCE.location}</span>
                    </div>
                    <ul style="padding-left: 1.25rem;">
                        {EXPERIENCE.highlights.map((highlight) => (
                            <li style="margin-bottom: 0.5rem; color: #c0c0d0;">{highlight}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Technical Skills -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">🛠️ Technical Skills</div>
                <div class="card-body">
                    {Object.entries(RESUME_SKILLS).map(([category, items]) => (
                        <div style="margin-bottom: 0.75rem;">
                            <strong style="color: #667eea;">{category}: </strong>
                            <span style="color: #c0c0d0;">{items}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <!-- Portfolio Projects -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">🚀 Portfolio Projects</div>
                <div class="card-body">
                    {RESUME_PROJECTS.map((project) => (
                        <div>
                            <strong style="color: #fff;">{project.name}</strong>
                            <span style="color: #667eea; font-size: 0.9rem;"> | {project.tech}</span>
                            <p style="color: #a0a0b0; margin-bottom: 0.75rem; margin-top: 0.25rem;">{project.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <!-- Education -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">🎓 Education</div>
                <div class="card-body">
                    <h5 style="margin-bottom: 0.25rem;">Anurag Group of Institutions</h5>
                    <p style="color: #a0a0b0; margin-bottom: 0;">M. Pharmacy - Pharmaceutical Analysis and Quality Assurance</p>
                    <span style="color: #667eea; font-size: 0.9rem;">JNTUH | May 2012</span>
                </div>
            </div>
        </div>
    </div>
</div>
</BaseLayout>
