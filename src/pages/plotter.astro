---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Data Plotter | Prashanth Kumar Kadasi" currentPath="/plotter">
<div class="container" style="position: relative; z-index: 1;">
    <!-- Hero Header -->
    <div class="row">
        <div class="col-12 text-center mb-4">
            <h2 style="display: inline-flex; align-items: center; gap: 0.75rem;">
                <i class="fas fa-chart-line" style="background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                Interactive Data Plotter
            </h2>
            <p class="mb-1">Upload CSV or Excel files and create beautiful interactive charts instantly.</p>
            <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
                <span class="plotter-badge"><i class="fas fa-file-csv"></i> CSV</span>
                <span class="plotter-badge"><i class="fas fa-file-excel"></i> XLSX / XLS</span>
                <span class="plotter-badge"><i class="fas fa-chart-pie"></i> 10 Chart Types</span>
                <span class="plotter-badge"><i class="fas fa-layer-group"></i> Multi-Series</span>
                <span class="plotter-badge"><i class="fas fa-download"></i> Export</span>
            </div>
        </div>
    </div>

    <!-- Upload Section -->
    <div class="row plotter-fade-in">
        <div class="col-12">
            <div class="card mb-4" style="overflow: visible;">
                <div class="card-header">
                    <span><i class="fas fa-cloud-upload-alt"></i> Upload Data File</span>
                    <span id="file-badge" class="plotter-file-badge" style="display: none;"></span>
                </div>
                <div class="card-body">
                    <div id="drop-zone" class="plotter-drop-zone">
                        <div class="plotter-drop-icon"><i class="fas fa-cloud-upload-alt"></i></div>
                        <p style="margin: 0; font-size: 1.1rem; font-weight: 500; color: var(--text-primary);">Drag & drop your file here</p>
                        <p style="margin: 0.25rem 0 0; font-size: 0.9rem;">or <span style="color: var(--accent-blue); text-decoration: underline; cursor: pointer;">click to browse</span></p>
                        <p style="margin: 0.5rem 0 0; font-size: 0.8rem; opacity: 0.6;">Supports .csv, .xlsx, .xls &bull; Max 10,000 rows</p>
                        <input type="file" id="file-input" accept=".csv,.xlsx,.xls" style="display: none;">
                    </div>
                    <div id="file-info" style="margin-top: 1rem; text-align: center;"></div>
                    <div id="sheet-selector-wrap" style="display: none; margin-top: 1rem;">
                        <label class="form-label"><i class="fas fa-layer-group"></i> Select Sheet</label>
                        <select class="form-select" id="sheet-selector"></select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading Spinner -->
    <div id="loading-spinner" style="display: none; text-align: center; padding: 2rem;">
        <div class="plotter-spinner"></div>
        <p style="margin-top: 1rem; color: var(--text-secondary);">Parsing your data...</p>
    </div>

    <!-- Data Preview -->
    <div class="row plotter-fade-in" id="preview-section" style="display: none;">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header">
                    <span><i class="fas fa-table"></i> Data Preview</span>
                    <div style="display: flex; gap: 0.5rem;">
                        <span id="row-badge" class="plotter-stat-badge"></span>
                        <span id="col-badge" class="plotter-stat-badge"></span>
                    </div>
                </div>
                <div class="card-body" style="padding: 0 !important;">
                    <div style="overflow-x: auto; max-height: 300px;">
                        <table class="table table-dark table-striped table-hover mb-0" id="data-table" style="font-size: 0.85rem;">
                            <thead id="table-head" style="position: sticky; top: 0; z-index: 2;"></thead>
                            <tbody id="table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Panel -->
    <div class="row plotter-fade-in" id="stats-section" style="display: none;">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header">
                    <span><i class="fas fa-calculator"></i> Column Statistics</span>
                    <button class="btn btn-sm" style="background: rgba(102,126,234,0.2); color: var(--accent-blue); font-size: 0.75rem; padding: 0.25rem 0.75rem !important;" onclick="toggleStats()">
                        <i class="fas fa-chevron-down" id="stats-toggle-icon"></i>
                    </button>
                </div>
                <div class="card-body" id="stats-body">
                    <div id="stats-grid" class="plotter-stats-grid"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Controls -->
    <div class="row plotter-fade-in" id="controls-section" style="display: none;">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-sliders-h"></i> Chart Controls</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <label class="form-label"><i class="fas fa-arrows-alt-h"></i> X-Axis</label>
                            <select class="form-select" id="x-axis"></select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <label class="form-label"><i class="fas fa-chart-bar"></i> Chart Type</label>
                            <select class="form-select" id="chart-type">
                                <optgroup label="Standard">
                                    <option value="bar">📊 Bar Chart</option>
                                    <option value="line">📈 Line Chart</option>
                                    <option value="scatter">🔵 Scatter Plot</option>
                                    <option value="area">🏔️ Area Chart</option>
                                </optgroup>
                                <optgroup label="Circular">
                                    <option value="pie">🥧 Pie Chart</option>
                                    <option value="doughnut">🍩 Doughnut Chart</option>
                                    <option value="polarArea">🎯 Polar Area</option>
                                    <option value="radar">🕸️ Radar Chart</option>
                                </optgroup>
                                <optgroup label="Advanced">
                                    <option value="horizontalBar">📊 Horizontal Bar</option>
                                    <option value="stackedBar">📊 Stacked Bar</option>
                                </optgroup>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <label class="form-label"><i class="fas fa-palette"></i> Color Theme</label>
                            <select class="form-select" id="color-theme">
                                <option value="gradient">🌈 Default Gradient</option>
                                <option value="ocean">🌊 Ocean</option>
                                <option value="sunset">🌅 Sunset</option>
                                <option value="forest">🌲 Forest</option>
                                <option value="neon">💡 Neon</option>
                                <option value="pastel">🎀 Pastel</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <label class="form-label"><i class="fas fa-heading"></i> Chart Title</label>
                            <input type="text" class="form-control" id="chart-title" placeholder="Auto-generated if empty...">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><i class="fas fa-arrows-alt-v"></i> Y-Axis Columns <small style="opacity: 0.6;">(select one or more numeric columns)</small></label>
                        <div id="y-axis-checkboxes" class="plotter-y-checkboxes"></div>
                    </div>

                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        <button class="btn btn-info" id="generate-btn" style="flex: 1; min-width: 200px;">
                            <i class="fas fa-magic"></i> Generate Chart
                        </button>
                        <button class="btn" id="download-png-btn" style="background: rgba(16,185,129,0.2); color: #10b981; display: none;" onclick="downloadChart('png')">
                            <i class="fas fa-image"></i> PNG
                        </button>
                        <button class="btn" id="download-svg-btn" style="background: rgba(139,92,246,0.2); color: #a855f7; display: none;" onclick="downloadChart('svg')">
                            <i class="fas fa-vector-square"></i> SVG
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Display -->
    <div class="row plotter-fade-in" id="chart-section" style="display: none;">
        <div class="col-12">
            <div class="card mb-4" style="overflow: visible;">
                <div class="card-header">
                    <span><i class="fas fa-chart-area"></i> Chart</span>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="btn btn-sm" style="background: rgba(102,126,234,0.2); color: var(--accent-blue); font-size: 0.75rem; padding: 0.25rem 0.75rem !important;" onclick="downloadChart('png')" title="Download PNG">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body" style="position: relative; min-height: 400px;">
                    <canvas id="chart-canvas"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SheetJS for XLSX parsing -->
<script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
<!-- Chart.js -->
<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

<script is:inline>
    let parsedData = [];
    let headers = [];
    let chart = null;
    let workbook = null;

    const COLOR_THEMES = {
        gradient: (count) => Array.from({ length: count }, (_, i) => `hsla(${(i * 360 / count) % 360}, 70%, 60%, 0.85)`),
        ocean: (count) => Array.from({ length: count }, (_, i) => `hsla(${190 + (i * 40 / count)}, 75%, ${45 + (i * 25 / count)}%, 0.85)`),
        sunset: (count) => Array.from({ length: count }, (_, i) => `hsla(${(i * 60 / count) + 0}, 80%, ${50 + (i * 15 / count)}%, 0.85)`),
        forest: (count) => Array.from({ length: count }, (_, i) => `hsla(${100 + (i * 60 / count)}, 60%, ${35 + (i * 25 / count)}%, 0.85)`),
        neon: (count) => {
            const neons = ['#ff006e', '#fb5607', '#ffbe0b', '#00f5d4', '#00bbf9', '#9b5de5', '#f15bb5', '#fee440', '#8ac926', '#1982c4'];
            return Array.from({ length: count }, (_, i) => neons[i % neons.length]);
        },
        pastel: (count) => Array.from({ length: count }, (_, i) => `hsla(${(i * 360 / count) % 360}, 55%, 75%, 0.85)`)
    };

    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');

    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-active'); });
    dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('drag-active'); });
    dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.classList.remove('drag-active'); const file = e.dataTransfer.files[0]; if (file) handleFile(file); });
    fileInput.addEventListener('change', (e) => { const file = e.target.files[0]; if (file) handleFile(file); });

    function handleFile(file) {
        const ext = file.name.split('.').pop().toLowerCase();
        if (!['csv', 'xlsx', 'xls'].includes(ext)) { showError('Unsupported file type.'); return; }
        const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
        const sizeStr = file.size > 1048576 ? `${sizeMB} MB` : `${(file.size / 1024).toFixed(1)} KB`;
        document.getElementById('file-info').innerHTML = `<span style="color: #10b981;"><i class="fas fa-check-circle"></i> ${file.name}</span> <span style="color: var(--text-secondary); margin-left: 0.5rem; font-size: 0.85rem;">(${sizeStr})</span>`;
        const badge = document.getElementById('file-badge');
        badge.textContent = ext.toUpperCase(); badge.style.display = 'inline-block';
        badge.className = 'plotter-file-badge ' + (ext === 'csv' ? 'csv' : 'xlsx');
        showLoading(true);
        if (ext === 'csv') { const reader = new FileReader(); reader.onload = (e) => { parseCSV(e.target.result); showLoading(false); }; reader.readAsText(file); }
        else { const reader = new FileReader(); reader.onload = (e) => { parseXLSX(e.target.result); showLoading(false); }; reader.readAsArrayBuffer(file); }
    }

    function parseCSV(text) {
        const rows = []; let current = ''; let inQuotes = false; const lines = [];
        for (let i = 0; i < text.length; i++) {
            const ch = text[i];
            if (ch === '"') { inQuotes = !inQuotes; current += ch; }
            else if ((ch === '\n' || ch === '\r') && !inQuotes) { if (current.trim()) lines.push(current); current = ''; if (ch === '\r' && text[i + 1] === '\n') i++; }
            else { current += ch; }
        }
        if (current.trim()) lines.push(current);
        for (const line of lines) {
            const fields = []; let field = ''; let q = false;
            for (let i = 0; i < line.length; i++) {
                const ch = line[i];
                if (ch === '"') { if (q && line[i + 1] === '"') { field += '"'; i++; } else q = !q; }
                else if (ch === ',' && !q) { fields.push(field.trim()); field = ''; }
                else { field += ch; }
            }
            fields.push(field.trim()); rows.push(fields);
        }
        if (rows.length < 2) { showError('File has insufficient data.'); return; }
        headers = rows[0]; parsedData = [];
        const limit = Math.min(rows.length, 10001);
        for (let i = 1; i < limit; i++) { if (rows[i].length === headers.length) { const row = {}; headers.forEach((h, idx) => row[h] = rows[i][idx]); parsedData.push(row); } }
        document.getElementById('sheet-selector-wrap').style.display = 'none'; workbook = null; onDataReady();
    }

    function parseXLSX(buffer) {
        try { workbook = XLSX.read(buffer, { type: 'array' }); } catch (err) { showError('Failed to parse Excel file: ' + err.message); return; }
        const sheetNames = workbook.SheetNames;
        const sheetWrap = document.getElementById('sheet-selector-wrap');
        const sheetSelect = document.getElementById('sheet-selector');
        if (sheetNames.length > 1) { sheetSelect.innerHTML = sheetNames.map(n => `<option value="${n}">${n}</option>`).join(''); sheetWrap.style.display = 'block'; sheetSelect.onchange = () => loadSheet(sheetSelect.value); }
        else { sheetWrap.style.display = 'none'; }
        loadSheet(sheetNames[0]);
    }

    function loadSheet(name) {
        const ws = workbook.Sheets[name]; const json = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
        if (json.length < 2) { showError('Sheet "' + name + '" has insufficient data.'); return; }
        headers = json[0].map(h => String(h).trim()); parsedData = [];
        const limit = Math.min(json.length, 10001);
        for (let i = 1; i < limit; i++) { if (json[i].length >= headers.length) { const row = {}; headers.forEach((h, idx) => row[h] = json[i][idx] != null ? String(json[i][idx]) : ''); parsedData.push(row); } }
        onDataReady();
    }

    function onDataReady() { displayPreview(); populateControls(); computeStats(); showSection('preview-section'); showSection('stats-section'); showSection('controls-section'); }

    function displayPreview() {
        document.getElementById('table-head').innerHTML = '<tr>' + headers.map(h => `<th style="white-space: nowrap; background: var(--bg-secondary); color: var(--accent-blue); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">${escapeHtml(h)}</th>`).join('') + '</tr>';
        document.getElementById('table-body').innerHTML = parsedData.slice(0, 10).map(row => '<tr>' + headers.map(h => `<td style="white-space: nowrap;">${escapeHtml(row[h])}</td>`).join('') + '</tr>').join('');
        document.getElementById('row-badge').innerHTML = `<i class="fas fa-list"></i> ${parsedData.length.toLocaleString()} rows`;
        document.getElementById('col-badge').innerHTML = `<i class="fas fa-columns"></i> ${headers.length} cols`;
    }

    function populateControls() {
        document.getElementById('x-axis').innerHTML = headers.map(h => `<option value="${escapeHtml(h)}">${escapeHtml(h)}</option>`).join('');
        const numericCols = headers.filter(h => parsedData.slice(0, 20).map(r => r[h]).some(v => !isNaN(parseFloat(v)) && v !== ''));
        document.getElementById('y-axis-checkboxes').innerHTML = headers.map(h => {
            const isNumeric = numericCols.includes(h);
            const checked = numericCols.length > 0 && h === numericCols[0] ? 'checked' : '';
            return `<label class="plotter-y-label${isNumeric ? '' : ' non-numeric'}"><input type="checkbox" name="y-col" value="${escapeHtml(h)}" ${checked}><span>${escapeHtml(h)}</span>${isNumeric ? '<i class="fas fa-hashtag" style="font-size: 0.6rem; opacity: 0.5;"></i>' : '<i class="fas fa-font" style="font-size: 0.6rem; opacity: 0.5;"></i>'}</label>`;
        }).join('');
    }

    function computeStats() {
        const grid = document.getElementById('stats-grid');
        const numericCols = headers.filter(h => parsedData.slice(0, 50).some(r => !isNaN(parseFloat(r[h])) && r[h] !== ''));
        if (numericCols.length === 0) { grid.innerHTML = '<p style="color: var(--text-secondary); text-align: center;">No numeric columns detected.</p>'; return; }
        grid.innerHTML = numericCols.map(col => {
            const vals = parsedData.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
            const count = vals.length, min = count ? Math.min(...vals) : 0, max = count ? Math.max(...vals) : 0;
            const sum = vals.reduce((a, b) => a + b, 0), mean = count ? (sum / count) : 0;
            return `<div class="plotter-stat-card"><div class="plotter-stat-title">${escapeHtml(col)}</div><div class="plotter-stat-row"><span>Count</span><span>${count.toLocaleString()}</span></div><div class="plotter-stat-row"><span>Min</span><span>${formatNum(min)}</span></div><div class="plotter-stat-row"><span>Max</span><span>${formatNum(max)}</span></div><div class="plotter-stat-row"><span>Mean</span><span>${formatNum(mean)}</span></div><div class="plotter-stat-row"><span>Sum</span><span>${formatNum(sum)}</span></div></div>`;
        }).join('');
    }

    let statsCollapsed = false;
    function toggleStats() { statsCollapsed = !statsCollapsed; document.getElementById('stats-body').style.display = statsCollapsed ? 'none' : 'block'; document.getElementById('stats-toggle-icon').className = statsCollapsed ? 'fas fa-chevron-right' : 'fas fa-chevron-down'; }

    document.getElementById('generate-btn').addEventListener('click', generateChart);

    function generateChart() {
        const xCol = document.getElementById('x-axis').value;
        const chartType = document.getElementById('chart-type').value;
        const themeId = document.getElementById('color-theme').value;
        const title = document.getElementById('chart-title').value;
        const yCols = Array.from(document.querySelectorAll('input[name="y-col"]:checked')).map(cb => cb.value);
        if (yCols.length === 0) { showError('Please select at least one Y-axis column.'); return; }
        const labels = parsedData.map(row => row[xCol]);
        const isCircular = ['pie', 'doughnut', 'polarArea', 'radar'].includes(chartType);
        const datasets = yCols.map((yCol, seriesIdx) => {
            const rawData = parsedData.map(row => parseFloat(row[yCol]) || 0);
            const colorFn = COLOR_THEMES[themeId] || COLOR_THEMES.gradient;
            const seriesColors = colorFn(isCircular ? rawData.length : yCols.length);
            const baseColor = isCircular ? seriesColors : (seriesColors[seriesIdx] || seriesColors[0]);
            const dataset = { label: yCol, data: chartType === 'scatter' ? parsedData.map(row => ({ x: parseFloat(row[xCol]) || 0, y: parseFloat(row[yCol]) || 0 })) : rawData, backgroundColor: isCircular ? seriesColors : baseColor, borderColor: isCircular ? seriesColors.map(c => c.replace('0.85', '1')) : baseColor, borderWidth: chartType === 'line' || chartType === 'area' ? 3 : 1, fill: chartType === 'area', tension: 0.4, pointRadius: chartType === 'scatter' ? 5 : (chartType === 'line' || chartType === 'area' ? 3 : 0), pointHoverRadius: 7 };
            if (chartType === 'area') { dataset.fill = true; dataset.backgroundColor = baseColor.replace('0.85', '0.2'); }
            return dataset;
        });
        let actualType = chartType;
        if (chartType === 'area') actualType = 'line';
        if (chartType === 'horizontalBar') actualType = 'bar';
        if (chartType === 'stackedBar') actualType = 'bar';
        const chartTitle = title || (yCols.length === 1 ? `${yCols[0]} by ${xCol}` : `${yCols.join(', ')} by ${xCol}`);
        showSection('chart-section');
        if (chart) chart.destroy();
        const ctx = document.getElementById('chart-canvas').getContext('2d');
        const config = { type: actualType, data: { labels: chartType === 'scatter' ? undefined : labels, datasets }, options: { responsive: true, maintainAspectRatio: false, animation: { duration: 800, easing: 'easeOutQuart' }, interaction: { intersect: false, mode: 'index' }, plugins: { title: { display: true, text: chartTitle, color: '#fff', font: { size: 18, weight: '600', family: 'Inter' }, padding: { bottom: 20 } }, legend: { display: yCols.length > 1 || isCircular, labels: { color: '#a0a0b0', usePointStyle: true, padding: 15, font: { family: 'Inter', size: 12 } } }, tooltip: { backgroundColor: 'rgba(15,15,26,0.95)', titleFont: { family: 'Inter', size: 13 }, bodyFont: { family: 'Inter', size: 12 }, padding: 12, cornerRadius: 8, borderWidth: 1, borderColor: 'rgba(102,126,234,0.3)' } }, scales: isCircular ? {} : { x: { ticks: { color: '#a0a0b0', font: { family: 'Inter', size: 11 }, maxTicksLimit: 20, maxRotation: 45 }, grid: { color: 'rgba(255,255,255,0.06)' } }, y: { ticks: { color: '#a0a0b0', font: { family: 'Inter', size: 11 } }, grid: { color: 'rgba(255,255,255,0.06)' }, stacked: chartType === 'stackedBar' } } } };
        if (chartType === 'horizontalBar') config.options.indexAxis = 'y';
        if (chartType === 'stackedBar') config.options.scales.x.stacked = true;
        chart = new Chart(ctx, config);
        document.getElementById('download-png-btn').style.display = 'inline-flex';
        document.getElementById('download-svg-btn').style.display = 'inline-flex';
        setTimeout(() => { document.getElementById('chart-section').scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
    }

    function downloadChart(format) {
        if (!chart) return;
        const canvas = document.getElementById('chart-canvas');
        if (format === 'png') { const link = document.createElement('a'); link.download = 'chart.png'; link.href = canvas.toDataURL('image/png', 1.0); link.click(); }
        else if (format === 'svg') { const link = document.createElement('a'); link.download = 'chart_hires.png'; const scale = 3; const tempCanvas = document.createElement('canvas'); tempCanvas.width = canvas.width * scale; tempCanvas.height = canvas.height * scale; const tempCtx = tempCanvas.getContext('2d'); tempCtx.scale(scale, scale); tempCtx.drawImage(canvas, 0, 0); link.href = tempCanvas.toDataURL('image/png', 1.0); link.click(); }
    }

    function showSection(id) { const el = document.getElementById(id); el.style.display = 'block'; el.style.opacity = '0'; el.style.transform = 'translateY(20px)'; requestAnimationFrame(() => { el.style.transition = 'opacity 0.5s ease, transform 0.5s ease'; el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }); }
    function showLoading(show) { document.getElementById('loading-spinner').style.display = show ? 'block' : 'none'; if (show) { ['preview-section', 'stats-section', 'controls-section', 'chart-section'].forEach(id => { document.getElementById(id).style.display = 'none'; }); } }
    function showError(msg) { document.getElementById('file-info').innerHTML = `<span style="color: #ef4444;"><i class="fas fa-exclamation-circle"></i> ${msg}</span>`; showLoading(false); }
    function escapeHtml(str) { if (str == null) return ''; return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
    function formatNum(n) { if (Number.isInteger(n)) return n.toLocaleString(); return n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 }); }
    document.getElementById('sheet-selector').addEventListener('change', function () { if (workbook) loadSheet(this.value); });
</script>
</BaseLayout>
