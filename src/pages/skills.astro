---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SKILLS } from '../data/skills';
---
<BaseLayout title="Skills | Prashanth Kumar Kadasi" currentPath="/skills">
<div class="container" style="position: relative; z-index: 1;">
    <div class="row">
        <div class="col-12">
            <h2>Technical Skills</h2>
            <p class="mb-4">A diverse toolkit spanning full-stack development, cloud infrastructure, and AI/ML.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">💻 Languages</div>
                <div class="card-body">
                    {SKILLS["Languages"].map(([skill, cat]) => (
                        <span class={`skill-badge ${cat}`}>{skill}</span>
                    ))}
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">⚡ Frameworks & Libraries</div>
                <div class="card-body">
                    {SKILLS["Frameworks & Libraries"].map(([skill, cat]) => (
                        <span class={`skill-badge ${cat}`}>{skill}</span>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">☁️ Cloud & DevOps</div>
                <div class="card-body">
                    {SKILLS["Cloud & DevOps"].map(([skill, cat]) => (
                        <span class={`skill-badge ${cat}`}>{skill}</span>
                    ))}
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">🤖 AI & ML</div>
                <div class="card-body">
                    {SKILLS["AI & ML"].map(([skill, cat]) => (
                        <span class={`skill-badge ${cat}`}>{skill}</span>
                    ))}
                </div>
            </div>
        </div>
    </div>
</div>
</BaseLayout>
